{
  "buildCommand": "npm run build",
  "framework": "vanilla",
  "public": "./",
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*"
    }
  ],
  "env": [
    "SCRAPECREATORS_API_KEY",
    "CLAUDE_API_KEY"
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x",
      "memory": 512
    }
  }
}
